// ─── Form submission ───
const form = document.getElementById('testForm');
const resultEl = document.getElementById('validationResult');

form.addEventListener('submit', function(e) {
    e.preventDefault();

    // Clear previous validation
    if (typeof CampusForms !== 'undefined') {
        CampusForms.clearValidation(this);
    }

    // Validate
    const result = typeof CampusForms !== 'undefined'
        ? CampusForms.validateForm(this)
        : { isValid: true, errors: [] };

    if (!result.isValid) {
        // Show error alert
        if (typeof showAlert !== 'undefined') {
            showAlert.error('Please fix the highlighted fields.', { duration: 4000 });
        }
        resultEl.style.display = 'block';
        resultEl.style.background = 'rgba(231, 76, 60, 0.08)';
        resultEl.style.border = '1px solid var(--red)';
        resultEl.style.color = 'var(--red)';
        resultEl.innerHTML = '<i class="fa-solid fa-circle-exclamation"></i> Please fix the highlighted fields.';
        return;
    }

    // Success – show toast
    if (typeof showAlert !== 'undefined') {
        showAlert.success('✅ Form submitted successfully!', { duration: 4000 });
    }

    resultEl.style.display = 'block';
    resultEl.style.background = 'rgba(13, 138, 62, 0.08)';
    resultEl.style.border = '1px solid var(--green)';
    resultEl.style.color = 'var(--green)';
    resultEl.innerHTML = '<i class="fa-solid fa-circle-check"></i> Form submitted successfully!';
});

// ─── Reset ───
form.addEventListener('reset', function() {
    setTimeout(() => {
        if (typeof CampusForms !== 'undefined') {
            CampusForms.clearValidation(this);
        }
        resultEl.style.display = 'none';
        // Clear file preview
        document.querySelectorAll('.file-drop-zone').forEach(zone => {
            zone.classList.remove('has-file');
            const container = zone.querySelector('.file-preview-container');
            if (container) container.innerHTML = '';
        });
    }, 50);
});