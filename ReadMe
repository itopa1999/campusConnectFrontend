// ============================================================
// 1. DELETE MODAL (Red / Danger)
//    Keywords: type: 'danger', confirmText: 'Delete'
// ============================================================
function showDeleteModal() {
    const modal = new Modal({
        title: 'Delete Item',
        body: `
            <p style="margin-bottom:8px;">Are you sure you want to delete <strong>"Engineering Mathematics"</strong>?</p>
            <p style="color:var(--text-muted); font-size:13px;">This action cannot be undone. All associated data will be permanently removed.</p>
        `,
        type: 'danger',
        confirmText: 'Yes, Delete It',
        cancelText: 'Cancel',
        onConfirm: function(instance) {
            // Simulate delete action
            showAlert.success('🗑️ Item deleted successfully!', { duration: 3000 });
            instance.close();
        },
        onCancel: function(instance) {
            showAlert.info('Delete cancelled.', { duration: 2000 });
            instance.close();
        },
        size: 'sm'
    });
    modal.open();
}

// ============================================================
// 2. WARNING MODAL (Orange / Warning)
//    Keywords: type: 'warning'
// ============================================================
function showWarningModal() {
    const modal = new Modal({
        title: '⚠️ Unverified Seller',
        body: `
            <p>This seller has not been verified by CampusHub.</p>
            <p style="color:var(--text-muted); font-size:13px; margin-top:8px;">Transactions with unverified sellers are at your own risk. We recommend using our secure payment system.</p>
            <div style="display:flex; gap:8px; margin-top:12px; flex-wrap:wrap;">
                <span style="background:var(--orange); color:#fff; padding:2px 12px; border-radius:20px; font-size:12px;">⚠️ Caution</span>
                <span style="background:var(--bg-input); color:var(--text-secondary); padding:2px 12px; border-radius:20px; font-size:12px;">📅 Joined 2 days ago</span>
            </div>
        `,
        type: 'warning',
        confirmText: 'Proceed Anyway',
        cancelText: 'Go Back',
        onConfirm: function(instance) {
            showAlert.warning('Proceeding with unverified seller...', { duration: 3000 });
            instance.close();
        },
        onCancel: function(instance) {
            instance.close();
        },
        size: 'md'
    });
    modal.open();
}

// ============================================================
// 3. CONFIRM MODAL (Green / Success)
//    Keywords: type: 'success' or 'default', confirmText: 'Confirm'
// ============================================================
function showConfirmModal() {
    const modal = new Modal({
        title: '✅ Confirm Enrollment',
        body: `
            <div style="display:flex; gap:16px; align-items:center; padding:8px 0;">
                <span style="font-size:42px;">📘</span>
                <div>
                    <h4 style="margin:0;">Engineering Mathematics</h4>
                    <p style="color:var(--green); font-weight:700; margin:4px 0;">₦3,500</p>
                    <p style="color:var(--text-muted); font-size:13px;">Lecturer: Dr. Adebayo • 30 spots left</p>
                </div>
            </div>
            <p style="margin-top:8px;">By confirming, you agree to the <a href="#" style="color:var(--green);">terms and conditions</a> of CampusHub.</p>
        `,
        type: 'success',
        confirmText: 'Confirm Enrollment',
        cancelText: 'Cancel',
        onConfirm: function(instance) {
            showAlert.success('🎉 You are now enrolled in Engineering Mathematics!', { duration: 4000 });
            instance.close();
        },
        onCancel: function(instance) {
            showAlert.info('Enrollment cancelled.', { duration: 2000 });
            instance.close();
        },
        size: 'md'
    });
    modal.open();
}

// ============================================================
// 4. INFO MODAL (Blue / Info)
//    Keywords: type: 'info'
// ============================================================
function showInfoModal() {
    const modal = new Modal({
        title: '📢 Campus Update',
        body: `
            <div style="background:var(--blue); color:#fff; padding:12px 16px; border-radius:12px; margin-bottom:12px;">
                <strong>📅 Fresher's Week</strong>
                <p style="margin:4px 0 0; opacity:0.9; font-size:13px;">Join us for Fresher's Week starting Monday! Free food, games, and networking.</p>
            </div>
            <p><strong>📍 Location:</strong> Main Hall, University of Benin</p>
            <p><strong>🕒 Time:</strong> 10:00 AM – 6:00 PM</p>
            <p style="color:var(--text-muted); font-size:13px; margin-top:4px;">💡 Bring your student ID for entry.</p>
        `,
        type: 'info',
        confirmText: 'Got it!',
        showCancel: false,
        onConfirm: function(instance) {
            showAlert.success('See you at Fresher\'s Week! 🎉', { duration: 3000 });
            instance.close();
        },
        size: 'md'
    });
    modal.open();
}




<script src="showAlert.js"></script>
<script>
    // Simple alerts
    showAlert.info('Welcome back, student!');
    showAlert.success('Item added to your cart 🎉');
    showAlert.error('Payment failed. Please try again.');
    showAlert.warning('Your session is about to expire.');

    // With options
    showAlert.success('Profile saved!', {
        duration: 3000,
        position: 'bottom-left',
        closable: true,
        onClose: () => console.log('Alert closed')
    });

    // Dismiss all
    showAlert.dismissAll();
</script>